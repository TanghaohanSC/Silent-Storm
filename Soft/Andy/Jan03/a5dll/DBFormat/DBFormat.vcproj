<?xml version="1.0" encoding = "windows-1251"?>
<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.00"
	Name="DBFormat"
	SccProjectName="&quot;$/A5/DBFormat&quot;, MDLAAAAA"
	SccAuxPath=""
	SccLocalPath="."
	SccProvider="MSSCCI:Microsoft Visual SourceSafe">
	<Platforms>
		<Platform
			Name="Win32"/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="FastDebug|Win32"
			OutputDirectory="../Binary/$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/Zm300"
				Optimization="0"
				OptimizeForProcessor="0"
				PreprocessorDefinitions="_WINDOWS,FAST_DEBUG,WIN32,_DEBUG,_USRDLL"
				MinimalRebuild="FALSE"
				BasicRuntimeChecks="0"
				RuntimeLibrary="3"
				BufferSecurityCheck="TRUE"
				EnableFunctionLevelLinking="FALSE"
				RuntimeTypeInfo="TRUE"
				UsePrecompiledHeader="3"
				PrecompiledHeaderThrough="StdAfx.h"
				PrecompiledHeaderFile="$(IntDir)/$(TargetName).pch"
				AssemblerListingLocation=".\FastDebug/"
				ObjectFile="$(IntDir)/"
				ProgramDataBaseFileName="$(IntDir)/vc70.pdb"
				WarningLevel="3"
				SuppressStartupBanner="TRUE"
				Detect64BitPortabilityProblems="FALSE"
				DebugInformationFormat="3"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="/IGNORE:4102"
				LinkIncremental="2"
				ModuleDefinitionFile="$(ConfigurationName).def"
				GenerateDebugInformation="TRUE"
				ImportLibrary="$(OutDir)/DBFormat.lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"
				PreprocessorDefinitions="_DEBUG"
				Culture="1049"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
		</Configuration>
		<Configuration
			Name="ReleaseDll|Win32"
			OutputDirectory="../Binary/$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/Zm300 /Ow"
				Optimization="3"
				GlobalOptimizations="TRUE"
				InlineFunctionExpansion="2"
				EnableIntrinsicFunctions="TRUE"
				FavorSizeOrSpeed="1"
				OmitFramePointers="FALSE"
				OptimizeForProcessor="2"
				PreprocessorDefinitions="WIN32,NDEBUG,_WINDOWS,_USRDLL"
				StringPooling="TRUE"
				MinimalRebuild="FALSE"
				RuntimeLibrary="2"
				BufferSecurityCheck="TRUE"
				EnableFunctionLevelLinking="FALSE"
				RuntimeTypeInfo="TRUE"
				UsePrecompiledHeader="3"
				PrecompiledHeaderThrough="StdAfx.h"
				PrecompiledHeaderFile="$(IntDir)/$(TargetName).pch"
				AssemblerListingLocation=".\ReleaseDll/"
				ObjectFile="$(IntDir)/"
				ProgramDataBaseFileName="$(IntDir)/vc70.pdb"
				WarningLevel="3"
				SuppressStartupBanner="TRUE"
				Detect64BitPortabilityProblems="FALSE"
				DebugInformationFormat="3"
				CallingConvention="1"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="/IGNORE:4102"
				LinkIncremental="2"
				ModuleDefinitionFile="$(ConfigurationName).def"
				GenerateDebugInformation="TRUE"
				ImportLibrary="$(OutDir)/DBFormat.lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"
				PreprocessorDefinitions="NDEBUG"
				Culture="1049"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
		</Configuration>
		<Configuration
			Name="Release|Win32"
			OutputDirectory="../Binary/$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/Zm300 /Ow"
				Optimization="3"
				GlobalOptimizations="TRUE"
				InlineFunctionExpansion="2"
				EnableIntrinsicFunctions="TRUE"
				FavorSizeOrSpeed="1"
				OmitFramePointers="TRUE"
				OptimizeForProcessor="2"
				PreprocessorDefinitions="WIN32,NDEBUG,_WINDOWS,_USRDLL"
				StringPooling="TRUE"
				MinimalRebuild="FALSE"
				BasicRuntimeChecks="0"
				RuntimeLibrary="2"
				BufferSecurityCheck="FALSE"
				EnableFunctionLevelLinking="FALSE"
				RuntimeTypeInfo="TRUE"
				UsePrecompiledHeader="3"
				PrecompiledHeaderThrough="StdAfx.h"
				PrecompiledHeaderFile="$(IntDir)/$(TargetName).pch"
				AssemblerListingLocation=".\Release/"
				ObjectFile="$(IntDir)/"
				ProgramDataBaseFileName="$(IntDir)/vc70.pdb"
				WarningLevel="3"
				SuppressStartupBanner="TRUE"
				Detect64BitPortabilityProblems="FALSE"
				DebugInformationFormat="3"
				CallingConvention="1"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="/IGNORE:4102"
				LinkIncremental="1"
				ModuleDefinitionFile="$(ConfigurationName).def"
				GenerateDebugInformation="TRUE"
				ImportLibrary="$(OutDir)/DBFormat.lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"
				PreprocessorDefinitions="NDEBUG"
				Culture="1049"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
		</Configuration>
		<Configuration
			Name="Debug|Win32"
			OutputDirectory="../Binary/$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="2"
			UseOfMFC="0"
			ATLMinimizesCRunTimeLibraryUsage="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/Zm300"
				Optimization="0"
				OptimizeForProcessor="0"
				PreprocessorDefinitions="WIN32,_DEBUG,_WINDOWS,_USRDLL"
				MinimalRebuild="TRUE"
				BasicRuntimeChecks="3"
				RuntimeLibrary="3"
				BufferSecurityCheck="TRUE"
				EnableFunctionLevelLinking="TRUE"
				RuntimeTypeInfo="TRUE"
				UsePrecompiledHeader="3"
				PrecompiledHeaderThrough="StdAfx.h"
				PrecompiledHeaderFile="$(IntDir)/$(TargetName).pch"
				AssemblerListingLocation=".\Debug/"
				ObjectFile="$(IntDir)/"
				ProgramDataBaseFileName="$(IntDir)/vc70.pdb"
				WarningLevel="3"
				SuppressStartupBanner="TRUE"
				Detect64BitPortabilityProblems="FALSE"
				DebugInformationFormat="4"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="/IGNORE:4102"
				LinkIncremental="2"
				ModuleDefinitionFile="$(ConfigurationName).def"
				GenerateDebugInformation="TRUE"
				ImportLibrary="$(OutDir)/DBFormat.lib"/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"
				PreprocessorDefinitions="_DEBUG"
				Culture="1049"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
		</Configuration>
	</Configurations>
	<Files>
		<Filter
			Name="DBFormat"
			Filter="">
			<File
				RelativePath=".\DataAI.cpp">
			</File>
			<File
				RelativePath=".\DataAI.h">
			</File>
			<File
				RelativePath=".\DataAck.cpp">
			</File>
			<File
				RelativePath=".\DataAck.h">
			</File>
			<File
				RelativePath=".\DataAnimation.h">
			</File>
			<File
				RelativePath="DataCamera.cpp">
			</File>
			<File
				RelativePath="DataCamera.h">
			</File>
			<File
				RelativePath="DataDifficulty.cpp">
			</File>
			<File
				RelativePath="DataDifficulty.h">
			</File>
			<File
				RelativePath=".\DataFormat.cpp">
			</File>
			<File
				RelativePath=".\DataFormat.h">
			</File>
			<File
				RelativePath=".\DataGeometry.h">
			</File>
			<File
				RelativePath=".\DataInterface.cpp">
			</File>
			<File
				RelativePath=".\DataInterface.h">
			</File>
			<File
				RelativePath="DataLight.h">
			</File>
			<File
				RelativePath=".\DataMap.cpp">
			</File>
			<File
				RelativePath=".\DataMap.h">
			</File>
			<File
				RelativePath="DataObject.h">
			</File>
			<File
				RelativePath="DataPerk.cpp">
			</File>
			<File
				RelativePath="DataPerk.h">
			</File>
			<File
				RelativePath=".\DataRPG.cpp">
			</File>
			<File
				RelativePath=".\DataRPG.h">
			</File>
			<File
				RelativePath=".\DataRPGTmp.cpp">
			</File>
			<File
				RelativePath=".\DataRPGTmp.h">
			</File>
			<File
				RelativePath="DataRpgConstants.cpp">
			</File>
			<File
				RelativePath="DataRpgConstants.h">
			</File>
			<File
				RelativePath="DataScenario.cpp">
			</File>
			<File
				RelativePath="DataScenario.h">
			</File>
			<File
				RelativePath="DataScript.cpp">
			</File>
			<File
				RelativePath="DataScript.h">
			</File>
			<File
				RelativePath="DataSound.h">
			</File>
			<File
				RelativePath=".\DataTerrain.h">
			</File>
			<File
				RelativePath="DataText.h">
			</File>
		</Filter>
		<Filter
			Name="Common"
			Filter="h;hpp;hxx;hm;inl;cpp;c;cxx;rc;def;r;odl;idl;hpj;bat">
			<File
				RelativePath="DataConst.cpp">
			</File>
			<File
				RelativePath="DataConst.h">
			</File>
			<File
				RelativePath=".\Specific.h">
			</File>
			<File
				RelativePath=".\StdAfx.cpp">
				<FileConfiguration
					Name="FastDebug|Win32">
					<Tool
						Name="VCCLCompilerTool"
						UsePrecompiledHeader="1"/>
				</FileConfiguration>
				<FileConfiguration
					Name="ReleaseDll|Win32">
					<Tool
						Name="VCCLCompilerTool"
						UsePrecompiledHeader="1"/>
				</FileConfiguration>
				<FileConfiguration
					Name="Release|Win32">
					<Tool
						Name="VCCLCompilerTool"
						UsePrecompiledHeader="1"/>
				</FileConfiguration>
				<FileConfiguration
					Name="Debug|Win32">
					<Tool
						Name="VCCLCompilerTool"
						UsePrecompiledHeader="1"/>
				</FileConfiguration>
			</File>
			<File
				RelativePath=".\StdAfx.h">
			</File>
			<File
				RelativePath=".\stl_user_config.h">
			</File>
		</Filter>
	</Files>
	<Globals>
	</Globals>
</VisualStudioProject>
