/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                       ID_APP_EXIT
        MENUITEM "Export template...",          ID_FILE_EXPORTTEMPLATE
        MENUITEM "Export Acks...",              ID_FILE_EXPORTACKS
    END
    POPUP "&View"
    BEGIN
        POPUP "Toolbars"
        BEGIN
            MENUITEM "Default",                     ID_VIEW_TOOLBARS_DEFAULT
            MENUITEM "Template tools",              ID_VIEW_TOOLBARS_TEMPLATETOOLS

            MENUITEM "Variant Selection",           ID_VIEW_TOOLBARS_VARIANTSELECTION

            MENUITEM "Paint",                       ID_VIEW_TOOLBARS_PAINT
        END
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM "Quick View",                  ID_VIEW_QUICKVIEW, GRAYED
        MENUITEM "&Properties",                 ID_VIEW_PROPERTIES
        MENUITEM "Layers",                      ID_VIEW_LAYERS
        MENUITEM "Building brushes",            ID_VIEW_BUILDBRUSH
        MENUITEM "Editor tools",                ID_VIEW_EDITORTOOLS
        MENUITEM "Realtime preview",            ID_VIEW_REALTIMEPREVIEW
        MENUITEM "&Grid",                       ID_VIEW_GRID
        MENUITEM SEPARATOR
        MENUITEM "Back\tAlt + LEFT",            ID_GOBACK
        MENUITEM "Forward\tAlt + RIGHT",        ID_GOFORWARD
        MENUITEM SEPARATOR
        MENUITEM "P&references...\tCtrl + P",   ID_VIEW_PREFERENCES
        MENUITEM SEPARATOR
        MENUITEM "New Tree",                    ID_NEWTREEVIEW
        MENUITEM "Update Game View",            ID_VIEW_UPDGAME
        MENUITEM "Camera reset",                ID_VIEW_CAMERARESET
        MENUITEM "Roll\tCtrl + R",              ID_VIEW_ROLL
        MENUITEM SEPARATOR
        MENUITEM "Full Screen\tCtrl + F",       ID_VIEW_FULLSCREEN
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Customize...",               ID_TOOLS_CUSTOMIZE
        MENUITEM "&Analyse Data",               ID_TOOLS_ANALYSE
        MENUITEM "&Build",                      ID_MAKE_CURRENT
        MENUITEM "Camera\tCtrl+I",              ID_TOOLS_CAMERA
        MENUITEM "Write RPGItem camera\tCtrl+W", ID_TOOLS_WRITERPGITEMCAMERA
        MENUITEM "Set game aspect ratio\t Ctrl+F1", 
                                                ID_TOOLS_SETGAMEASPECTRATIO
        MENUITEM "&Edit store items...",        ID_TOOLS_STOREITEMS
    END
    POPUP "Te&mplate"
    BEGIN
        POPUP "Mode"
        BEGIN
            MENUITEM "Paint",                       ID_TEMPLATE_MODE_PAINT
            MENUITEM "Zoom",                        ID_TEMPLATE_MODE_ZOOM
            MENUITEM "Pan",                         ID_TEMPLATE_MODE_PAN
        END
        MENUITEM "Edit script\tCtrl+S",         ID_TEMPLATE_EDITSCRIPT
    END
    POPUP "&Help", HELP
    BEGIN
        MENUITEM "&Tip of the Day...",          ID_HELP_TIPOFTHEDAY
        MENUITEM SEPARATOR
        MENUITEM "&About MapEdit...",           ID_APP_ABOUT
    END
END

IDR_TEDITTYPE MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Toolbar",                    ID_VIEW_TOOLBAR
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM "&Properties",                 ID_VIEW_PROPERTIES
        POPUP "Zoom"
        BEGIN
            MENUITEM "50%",                         ID_VIEW_ZOOM_50
            MENUITEM "100%",                        ID_VIEW_ZOOM_100
            MENUITEM "200%",                        ID_VIEW_ZOOM_200
        END
        MENUITEM "Update Game View",            ID_VIEW_UPDGAME
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Customize...",               ID_TOOLS_CUSTOMIZE
        MENUITEM "Reload Tree",                 ID_UPDATE_TREE
        MENUITEM "Resources",                   ID_TOOLS_RESOURCES
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About MapEdit...",           ID_APP_ABOUT
    END
    POPUP "Te&mplate"
    BEGIN
        POPUP "Mode"
        BEGIN
            MENUITEM "Draw rects",                  ID_TEMPLATE_MODE_NORMAL
            MENUITEM "Zoom",                        ID_TEMPLATE_MODE_ZOOM
            MENUITEM "Pan",                         ID_TEMPLATE_MODE_PAN
            MENUITEM "Draw walls",                  ID_DRAW_WALLS
        END
    END
END

IDR_RECTMENU MENU 
BEGIN
    POPUP "="
    BEGIN
        MENUITEM "Add Template",                ID_ADDTEMPLATE
        MENUITEM "Delete Template",             ID_DELTEMPLATE
    END
END

