        MENUITEM "New Folder...",               ID_NEWFOLDER
        MENUITEM "Delete Folder",               ID_DELETEFOLDER
        MENUITEM SEPARATOR
        MENUITEM "Rename",                      ID_RENAMEITEM
        MENUITEM "New Item...\t Ins",           ID_NEWITEM
        MENUITEM "Delete Item\tDel",            ID_DELETEITEM
        MENUITEM SEPARATOR
        MENUITEM "Export",                      ID_EXPORTITEM
        MENUITEM "Export (overwrite)",          ID_FORCED_EXPORTITEM
        MENUITEM "Update DB values",            ID_UPDATEDBVALUES
        MENUITEM "Copy selected names",         ID_COPYSELECTEDNAMES
        MENUITEM SEPARATOR
        MENUITEM "Color...",                    ID_FOLDER_COLOR
        MENUITEM "Find...\tF3",                 ID_FOLDER_FIND
    END
END

