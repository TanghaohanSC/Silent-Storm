    "F",            ID_VIEW_FULLSCREEN,     VIRTKEY, CONTROL, NOINVERT
    "P",            ID_VIEW_PREFERENCES,    VIRTKEY, CONTROL, NOINVERT
    "R",            ID_VIEW_ROLL,           VIRTKEY, CONTROL, NOINVERT
