<?xml version="1.0" encoding = "windows-1251"?>
<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.00"
	Name="zlib"
	SccProjectName="&quot;$/A5/zlib&quot;, ZDOAAAAA"
	SccAuxPath=""
	SccLocalPath="."
	SccProvider="MSSCCI:Microsoft Visual SourceSafe">
	<Platforms>
		<Platform
			Name="Win32"/>
